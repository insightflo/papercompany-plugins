{
  "name": "@insightflo/paperclip-github-repository-bridge",
  "version": "0.1.0",
  "description": "GitHub repository intake bridge for Papercompany",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "tsx --test ./tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "file:../../.paperclip-sdk/plugin-sdk",
    "@paperclipai/shared": "file:../../.paperclip-sdk/shared"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
